
@model IEnumerable<Plan>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Baloo+Thambi+2:wght@400..800&family=Rubik:ital,wght@0,300..900;1,300..900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <!-- ^ Bootstrap 5.3.8 css file -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- ^ Our main css file>>~read from www golder --> 
    <link rel="stylesheet" href="~/css/style.css" />
    <title>Power fitness | Home</title>
</head>

<body>
    <header>
        <!-- ^ navbar -->
        <nav class="navbar navbar-expand-lg bg-white my-3">
            <div class="container">
                <a class="navbar-brand" href="#">
                    <img src="~/images/logo.jpg" alt="" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav m-auto mb-2 mb-lg-0 mt-3 mt-lg-0">
                        <li class="nav-item">
                        <li class="nav-item">
                            <a class="nav-link active px-3 py-2 mx-2 fw-bolder fs-5" aria-current="page"
                               href="#">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link  px-3 py-2 mx-2 fw-bolder fs-5" aria-current="page" href="#">Members</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link  px-3 py-2 mx-2 fw-bolder fs-5" aria-current="page" href="#">Trainers</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link  px-3 py-2 mx-2 fw-bolder fs-5" aria-current="page" href="#">Sessions</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5" aria-current="page" href="#">Plans</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5" aria-current="page"
                               href="#">Memberships</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5" aria-current="page" href="#">
                                Sessions
                                Schedule
                            </a>
                        </li>
                        <li class="nav-item">
                            <form href="\Account\Logout" method="post" class="d-inline">
                                <button type="submit"
                                        class="btn btn-link nav-link px-3 py-2 mx-2 fw-bolder fs-5 text-black-alternative">
                                    Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            <div class="container">
              <header class="d-flex justify-content-between mt-5 mb-4 align-items-center">
                    <div>
                        <h2 class="text-primary-color mb-0">Membership Plans</h2>
                        <p class="text-muted">Manage your gym membership packages</p>
                    </div>
                </header>
                @if (Model.Any())
                {
                    <div class="row g-4">
                      @foreach (var plan in Model)
                       {
                        
                            @* Loop Through Plans and Display Each Plan in a Card *@
                            <div class="col-12 col-md-6 col-lg-4">
                                <div class="card h-100 shadow-sm border-0 plan-card">
                                    @* If Plan is Active put class bg-primary-color if not bg-secondary *@
                                    <div class="card-header text-white text-center py-4 @(plan.IsActive ? "bg-primary-color" : "bg-secondary")  ">
                                        <h4 class="mb-0">@plan.Name</h4>
                                    </div>
                                    <div class="card-body d-flex flex-column">
                                        <div class="text-center mb-4">
                                            <div class="display-4 fw-bold text-primary-color">@plan.Price</div>
                                            <small class="text-muted">EGP</small>
                                        </div>

                                        <div class="mb-3">
                                            <p class="text-muted mb-2">
                                                <i class="bi bi-calendar-check text-primary-color me-2"></i>
                                                <strong>Duration:</strong> @plan.DurationDays
                                            </p>
                                            <p class="text-muted mb-3">
                                                <i class="bi bi-file-text text-primary-color me-2"></i>
                                                <strong>Description:</strong>
                                            </p>
                                            <p class="small">@plan.Description</p>
                                        </div>

                                        <div class="mt-auto">
                                            <div class="d-grid gap-2">

                                                <a href="\Plans\Details\@plan.Id" class="btn btn-outline btn-sm">
                                                    <i class="bi bi-eye me-1"></i>View Details
                                                </a>

                                                <div class="d-flex gap-2">
                                                    <a href="\Plans\Edit\@plan.Id" class="btn btn-outline btn-sm flex-fill">
                                                        <i class="bi bi-pencil me-1"></i>Edit
                                                    </a>
                                                    <form href="\Plans\Activate\@plan.Id" method="post" class="flex-fill">
                                                        @* If Plan is Active put class text-danger if not text-success *@
                                                        <button type="submit" class="btn btn-outline btn-sm w-100 @(plan.IsActive ? "text-danger" : "text-success")">
                                                            @* Display If No Plan is inactive*@
                                                            @if (plan.IsActive)
                                                            {
                                                                <i class="bi bi-x-circle me-1"> Deactivate </i>
                                                            }
                                                            else
                                                            {

                                                                @* Display If No Plan is Active*@
                                                                <i class="bi bi-check-circle me-1"> Activate </i>
                                                            }





                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                     
                    }
                    </div>
                }
                else

                   {
        @* Display This Div If No Plans Are Available *@

                    <div class="text-center py-5">
                        <i class="bi bi-inbox display-1 text-muted"></i>
                        <h4 class="mt-3 text-muted">No Plans Available</h4>
                    </div>
                }
               
            
          
            
            
            </div>
        </main>
    </div>
</body>
</html>

